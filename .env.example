# ─────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Marmelad CRM"

# ─────────────────────────────────────────────
# DATABASE — PostgreSQL
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marmelad_crm?schema=public"

# ─────────────────────────────────────────────
# CACHE & QUEUES — Redis
# ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────
# TABOOLA — Phase 2
# ─────────────────────────────────────────────
TABOOLA_CLIENT_ID=
TABOOLA_CLIENT_SECRET=
TABOOLA_ACCOUNT_ID=

# ─────────────────────────────────────────────
# KEITARO — Phase 2
# ─────────────────────────────────────────────
KEITARO_API_URL=
KEITARO_API_KEY=
