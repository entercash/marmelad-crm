# ─────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Marmelad CRM"

# ─────────────────────────────────────────────
# DATABASE — PostgreSQL
# ─────────────────────────────────────────────
# Local (matches docker-compose.yml defaults):
#   postgresql://postgres:postgres@localhost:5432/marmelad_crm?schema=public
# Production: use a connection pooler (e.g. PgBouncer / Supabase pooler)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marmelad_crm?schema=public"

# ─────────────────────────────────────────────
# CACHE & QUEUES — Redis
# ─────────────────────────────────────────────
# Local (matches docker-compose.yml defaults):
#   redis://localhost:6379
# Production: redis://:password@host:6379 or rediss:// for TLS
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────
# TABOOLA — Backstage API
# ─────────────────────────────────────────────
# OAuth2 credentials — obtain from:
#   https://backstage.taboola.com/backstage/settings/api-connect
#
# TABOOLA_CLIENT_ID    — "Client ID" shown in API Connect settings
# TABOOLA_CLIENT_SECRET — "Client Secret" shown in API Connect settings
# TABOOLA_ACCOUNT_ID   — Your top-level account ID (numeric string, e.g. "1234567")
#                        Visible in the Backstage URL or account settings.
#                        Used as the default account when no accountId is supplied.
TABOOLA_CLIENT_ID=
TABOOLA_CLIENT_SECRET=
TABOOLA_ACCOUNT_ID=

# Optional — override API base URL if using a sandbox or proxy
# TABOOLA_BASE_URL=https://backstage.taboola.com

# ─────────────────────────────────────────────
# KEITARO — Tracker API
# ─────────────────────────────────────────────
# KEITARO_API_URL — Full base URL of your self-hosted Keitaro instance,
#                   including protocol and trailing path if needed.
#                   Example: https://track.yourdomain.com
# KEITARO_API_KEY — API key from: Keitaro Admin → Settings → API
#                   The key must have "Reports" read access.
KEITARO_API_URL=https://track.yourdomain.com
KEITARO_API_KEY=

# Optional — request timeout in ms for Keitaro report API (default: 30000)
# KEITARO_TIMEOUT_MS=30000

# ─────────────────────────────────────────────
# WORKER PROCESS
# ─────────────────────────────────────────────
# These control the standalone BullMQ worker (npm run worker).
# In most cases the defaults are fine; adjust for high-volume deployments.

# Max simultaneous jobs per worker process (default: 2)
# WORKER_CONCURRENCY=2

# Stalled job detection interval in ms (default: 30000)
# WORKER_STALLED_INTERVAL=30000
