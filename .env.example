# ─────────────────────────────────────────────
# HOW TO USE THIS FILE
# ─────────────────────────────────────────────
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# ⚠️  DOCKER vs LOCAL URLs
#     When the app runs INSIDE Docker Compose, use Docker service names:
#       DATABASE_URL=postgresql://postgres:postgres@postgres:5432/marmelad_crm?schema=public
#       REDIS_URL=redis://redis:6379
#     When the app runs on your HOST machine (npm run dev), use localhost:
#       DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marmelad_crm?schema=public
#       REDIS_URL=redis://localhost:6379
#     The examples below show the LOCAL (host-machine) values.

# ─────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Marmelad CRM"

# ─────────────────────────────────────────────
# DATABASE — PostgreSQL
# ─────────────────────────────────────────────
# ⚠️  DOCKER vs LOCAL — pick ONE and comment out the other.
#
# Docker Compose (app container → postgres container, use service name):
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/marmelad_crm?schema=public"
#
# Local dev (app on host → postgres port-mapped, use localhost).
# Put this in .env.local so it overrides .env without editing this file:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marmelad_crm?schema=public"
#
# IMPORTANT: credentials here (user:password) must match
# POSTGRES_USER and POSTGRES_PASSWORD in docker-compose.yml.
# If they drift, destroy the postgres volume and recreate:
#   docker compose down -v && docker compose up -d --build

# ─────────────────────────────────────────────
# CACHE & QUEUES — Redis
# ─────────────────────────────────────────────
# Used by: ioredis singleton (lib/redis.ts) AND BullMQ connection options
# (lib/bullmq-connection.ts parses this URL — no separate REDIS_HOST/PORT needed).
#
# Docker Compose (use service name):
REDIS_URL="redis://redis:6379"
#
# Local dev (redis port-mapped, use localhost — put in .env.local to override):
# REDIS_URL="redis://localhost:6379"
#
# With password:     redis://:yourpassword@host:6379
# With TLS:          rediss://host:6379

# ─────────────────────────────────────────────
# TABOOLA — Backstage API
# ─────────────────────────────────────────────
# OAuth2 credentials — obtain from:
#   https://backstage.taboola.com/backstage/settings/api-connect
#
# TABOOLA_CLIENT_ID    — "Client ID" shown in API Connect settings
# TABOOLA_CLIENT_SECRET — "Client Secret" shown in API Connect settings
# TABOOLA_ACCOUNT_ID   — Your top-level account ID (numeric string, e.g. "1234567")
#                        Visible in the Backstage URL or account settings.
#                        Used as the default account when no accountId is supplied.
TABOOLA_CLIENT_ID=
TABOOLA_CLIENT_SECRET=
TABOOLA_ACCOUNT_ID=

# Optional — override API base URL if using a sandbox or proxy
# TABOOLA_BASE_URL=https://backstage.taboola.com

# ─────────────────────────────────────────────
# KEITARO — Tracker API
# ─────────────────────────────────────────────
# KEITARO_API_URL — Full base URL of your self-hosted Keitaro instance,
#                   including protocol and trailing path if needed.
#                   Example: https://track.yourdomain.com
# KEITARO_API_KEY — API key from: Keitaro Admin → Settings → API
#                   The key must have "Reports" read access.
KEITARO_API_URL=https://track.yourdomain.com
KEITARO_API_KEY=

# Optional — request timeout in ms for Keitaro report API (default: 30000)
# KEITARO_TIMEOUT_MS=30000

# ─────────────────────────────────────────────
# WORKER PROCESS
# ─────────────────────────────────────────────
# These control the standalone BullMQ worker (npm run worker).
# In most cases the defaults are fine; adjust for high-volume deployments.

# Max simultaneous jobs per worker process (default: 2)
# WORKER_CONCURRENCY=2

# Stalled job detection interval in ms (default: 30000)
# WORKER_STALLED_INTERVAL=30000
